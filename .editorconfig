root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.{json,yml,yaml,xml,csproj,props,targets,slnx,sln}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

# EF Core migrations are generated code — exempt them from our style/analyzer gate.
[**/Migrations/*.cs]
generated_code = true
dotnet_diagnostic.IDE0161.severity = none
dotnet_diagnostic.CA1861.severity = none

[*.cs]
# Using directives
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# Newlines
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true

# Code style
csharp_prefer_braces = true:warning
csharp_style_namespace_declarations = file_scoped:warning
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:silent
csharp_style_expression_bodied_properties = when_on_single_line:silent

# Naming
dotnet_naming_rule.interface_should_be_begins_with_i.severity = warning
dotnet_naming_rule.interface_should_be_begins_with_i.symbols = interface
dotnet_naming_rule.interface_should_be_begins_with_i.style = begins_with_i
dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_style.begins_with_i.required_prefix = I
dotnet_naming_style.begins_with_i.capitalization = pascal_case

# Analyzer suppressions — patterns we deliberately use that conflict with default CA rules.

# CA1000: Do not declare static members on generic types
# Reason: Result<T>.Success / Failure / ValidationFailure are idiomatic Result pattern.
dotnet_diagnostic.CA1000.severity = none

# CA1030: Use events where appropriate
# Reason: Entity.Raise(IDomainEvent) is DDD domain events, not C# events.
dotnet_diagnostic.CA1030.severity = none

# CA1040: Avoid empty interfaces
# Reason: IDomainEvent is a marker interface — a deliberate DDD pattern.
dotnet_diagnostic.CA1040.severity = none

# CA1711: Identifiers should not have incorrect suffix
# Reason: IDomainEventHandler is the DDD term, deliberately ends in 'EventHandler'.
dotnet_diagnostic.CA1711.severity = none

# CA1716: Identifiers should not match reserved keywords
# Reason: 'Error' is the canonical name in Result-pattern code.
dotnet_diagnostic.CA1716.severity = none

# CA1819: Properties should not return arrays
# Reason: ValidationError.Errors exposes the violation list to the caller; the cost of
#         copying every read is not worth a defensive copy here.
dotnet_diagnostic.CA1819.severity = none

# CA2225: Operator overloads have named alternates
# Reason: implicit operator T -> Result<T> is the Result-pattern ergonomics we want.
dotnet_diagnostic.CA2225.severity = none

# CA1515: Consider making public types internal
# Reason: xUnit discovers public test classes; ArchitectureTests intentionally exposes types.
dotnet_diagnostic.CA1515.severity = none

# CA1707: Identifiers should not contain underscores
# Reason: xUnit convention is Method_Should_Behavior — readable test names trump the rule.
dotnet_diagnostic.CA1707.severity = none

# CA1724: Type names should not match namespaces
# Reason: DDD feature-folder convention names the aggregate after the folder
#         (Domain.Examples.Example, Domain.Orders.Order). This is intentional.
dotnet_diagnostic.CA1724.severity = none

# CA1812: Avoid uninstantiated internal classes
# Reason: Handlers are 'internal sealed' and constructed by the DI container at runtime.
#         The analyzer can't see DI registrations.
dotnet_diagnostic.CA1812.severity = none

# CA2007: Consider calling ConfigureAwait on the awaited task
# Reason: Application code runs without a SynchronizationContext (ASP.NET Core, console).
#         ConfigureAwait(false) is noise for application/web code.
dotnet_diagnostic.CA2007.severity = none

# CA1062: Validate arguments of public methods
# Reason: Nullable reference types already enforce non-null at the type level.
#         Adding null checks on top of NRT-annotated parameters is redundant.
dotnet_diagnostic.CA1062.severity = none

# CA1848: Use the LoggerMessage delegates
# Reason: Source-generated loggers are an optimization for high-volume hot paths.
#         For low-rate paths (exception handlers, startup) plain ILogger calls are clearer.
dotnet_diagnostic.CA1848.severity = none

# CA1307: Specify StringComparison for clarity
# Reason: NetArchTest's fluent API (HaveNameEndingWith) accepts only a string; no overload
#         takes StringComparison. Suppressing globally keeps test code readable.
dotnet_diagnostic.CA1307.severity = none

# CA2234: Pass System.Uri objects instead of strings
# Reason: Test code calling HttpClient.GetAsync(string)/PostAsync(string) is idiomatic.
#         Forcing Uri allocation in tests adds ceremony without benefit.
dotnet_diagnostic.CA2234.severity = none

# CA1308: Normalize strings to uppercase
# Reason: Emails and usernames are stored lowercase on purpose (case-insensitive identifiers).
#         ToLowerInvariant() is culture-safe; uppercasing them would be wrong for this domain.
dotnet_diagnostic.CA1308.severity = none
